{
  "name": "al-wisam-dental",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node ./scripts/ensure-staff.mjs",
    "db:ensure-staff": "node ./scripts/ensure-staff.mjs",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "setup": "npm run docker:up && npm run db:migrate && npm run db:seed"
  },
  "prisma": {
    "seed": "node ./scripts/ensure-staff.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
