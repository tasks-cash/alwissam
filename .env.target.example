# Al-Wisam target architecture environment template (names only).
# Copy to .env and fill values. Do not commit secrets.
# Legacy PostgreSQL app continues to use root DATABASE_URL separately.

NODE_ENV=development
APP_ENV=development

WEB_PORT=3003
API_PORT=4001

NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:4001

API_URL=http://localhost:4001
MONGODB_URI=mongodb://alwisam:alwisam_mongo_change_me@localhost:27018/alwisam?authSource=admin

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Legacy Postgres (migration source — read-only for migration tools)
LEGACY_DATABASE_URL=
MIGRATION_CONFIRM_EXECUTION=
MIGRATION_VERSION=v1

# Redis (parity with legacy rate-limit / pubsub)
REDIS_URL=redis://localhost:6380

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
