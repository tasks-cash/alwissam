# Al Wisam Dental Clinic - Environment Variables
# Copy to .env and fill in values before running

# Database
POSTGRES_USER=alwisam
POSTGRES_PASSWORD=alwisam_secure_change_me
POSTGRES_DB=alwisam_dental
DATABASE_URL=postgresql://alwisam:alwisam_secure_change_me@localhost:5433/alwisam_dental?schema=public

# MongoDB (primary auth store for target stack)
MONGODB_URI=

# Nest API
API_PORT=4001
WEB_ORIGIN=http://localhost:3003
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6380

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=عيادة الوسام لطب الأسنان

# Auth / Security
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
CSRF_SECRET=change-me-csrf-secret-at-least-32-chars
COOKIE_SECURE=false
SESSION_MAX_AGE_HOURS=12
SESSION_REMEMBER_DAYS=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# Seed account passwords (required for prisma db seed)
SEED_ADMIN_EMAIL=admin@alwisam.dz
SEED_ADMIN_PHONE=0550000001
SEED_ADMIN_PASSWORD=ChangeMe_Admin_123!

SEED_SECRETARY1_EMAIL=samar@alwisam.dz
SEED_SECRETARY1_PHONE=0550000002
SEED_SECRETARY1_PASSWORD=ChangeMe_Secretary_123!

SEED_DOCTOR_SPECIALIST_EMAIL=manana@alwisam.dz
SEED_DOCTOR_SPECIALIST_PHONE=0550000003
SEED_DOCTOR_SPECIALIST_PASSWORD=ChangeMe_Doctor_123!

SEED_DOCTOR_GENERAL_EMAIL=wakri@alwisam.dz
SEED_DOCTOR_GENERAL_PHONE=0550000004
SEED_DOCTOR_GENERAL_PASSWORD=ChangeMe_Doctor_123!

# Production owner/admin (npm run seed:owner) — names only; set real values in local .env
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_PHONE=
OWNER_FULL_NAME=

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
SIGNED_URL_SECRET=change-me-signed-url-secret

# Optional notification providers (provider-ready)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@alwisam.dz

SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=

WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_FROM=

# Clinic contact (public site)
CLINIC_PHONE=0550000000
CLINIC_EMAIL=contact@alwisam.dz
CLINIC_ADDRESS=الجزائر
CLINIC_MAP_EMBED_URL=

# Production owner (Mongo seed: pnpm seed:owner) — values only in local .env
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_PHONE=
OWNER_FULL_NAME=
