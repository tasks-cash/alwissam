{
  "name": "al-wisam-dental",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @alwisam/web dev",
    "dev:api": "pnpm --filter @alwisam/api dev",
    "build": "pnpm build:target",
    "build:web": "NODE_ENV=production pnpm --filter @alwisam/web build",
    "build:api": "pnpm --filter @alwisam/shared-config build && pnpm --filter @alwisam/shared-types build && pnpm --filter @alwisam/api build",
    "build:target": "pnpm --filter @alwisam/shared-config build && pnpm --filter @alwisam/shared-types build && pnpm --filter @alwisam/shared-validation build && pnpm --filter @alwisam/shared-utils build && pnpm --filter @alwisam/api build && NODE_ENV=production pnpm --filter @alwisam/web build",
    "start": "pnpm --filter @alwisam/web start",
    "lint": "pnpm lint:target",
    "typecheck": "pnpm typecheck:target",
    "typecheck:target": "pnpm --filter @alwisam/shared-config typecheck && pnpm --filter @alwisam/shared-types typecheck && pnpm --filter @alwisam/shared-validation typecheck && pnpm --filter @alwisam/shared-utils typecheck && pnpm --filter @alwisam/api typecheck && pnpm --filter @alwisam/web typecheck",
    "lint:target": "pnpm --filter @alwisam/api lint && pnpm --filter @alwisam/web lint",
    "test": "pnpm test:target",
    "test:target": "pnpm --filter @alwisam/shared-validation test && pnpm --filter @alwisam/api test",
    "test:e2e": "pnpm --filter @alwisam/web test:e2e",
    "seed:owner": "tsx scripts/seed-mongo-owner.ts",
    "seed:owner:mongo": "tsx scripts/seed-mongo-owner.ts",
    "seed:clinic-contact": "tsx scripts/update-clinic-contact.ts",
    "seed:clinic-doctors": "tsx scripts/ensure-clinic-doctors.ts",
    "seed:catalog": "tsx scripts/seed-catalog.ts",
    "seed:faqs": "tsx scripts/seed-faqs.ts",
    "seed:reviews": "tsx scripts/seed-reviews.ts",
    "migration:dry-run": "tsx scripts/migration/dry-run.ts",
    "migration:execute": "tsx scripts/migration/execute.ts",
    "migration:verify": "tsx scripts/migration/verify.ts",
    "legacy:dev": "echo 'Legacy Next+Prisma stack disabled for production path. Use apps/web + apps/api.'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-jalali": "^4.4.0-0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "mongoose": "^8.12.1",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
