{
  "name": "al-wisam-dental",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed/index.ts",
    "seed:owner": "tsx scripts/seed-mongo-owner.ts",
    "seed:owner:mongo": "tsx scripts/seed-mongo-owner.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "setup": "npm run docker:up && npm run db:migrate && npm run db:seed",
    "dev:web": "pnpm --filter @alwisam/web dev",
    "dev:api": "pnpm --filter @alwisam/api dev",
    "build:web": "pnpm --filter @alwisam/web build",
    "build:api": "pnpm --filter @alwisam/shared-config build && pnpm --filter @alwisam/shared-types build && pnpm --filter @alwisam/api build",
    "build:target": "pnpm --filter @alwisam/shared-config build && pnpm --filter @alwisam/shared-types build && pnpm --filter @alwisam/shared-validation build && pnpm --filter @alwisam/shared-utils build && pnpm --filter @alwisam/api build && pnpm --filter @alwisam/web build",
    "typecheck:target": "pnpm --filter @alwisam/shared-config typecheck && pnpm --filter @alwisam/shared-types typecheck && pnpm --filter @alwisam/shared-validation typecheck && pnpm --filter @alwisam/shared-utils typecheck && pnpm --filter @alwisam/api typecheck && pnpm --filter @alwisam/web typecheck",
    "lint:target": "pnpm --filter @alwisam/api lint && pnpm --filter @alwisam/web lint",
    "test:target": "pnpm --filter @alwisam/shared-validation test && pnpm --filter @alwisam/api test",
    "migration:dry-run": "tsx scripts/migration/dry-run.ts",
    "migration:execute": "tsx scripts/migration/execute.ts",
    "migration:verify": "tsx scripts/migration/verify.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-jalali": "^4.4.0-0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "mongoose": "^8.12.1",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
